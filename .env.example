# Applications
WEB_PORT=3000
API_PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# Generate with: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Local development prints OTP codes to the API terminal.
OTP_DELIVERY=console

# Runtime role is subject to Row Level Security.
DATABASE_URL=postgresql://docvault_app:docvault_app@localhost:5432/document_saas
# Admin role is used only by Drizzle migrations.
DATABASE_ADMIN_URL=postgresql://app:app@localhost:5432/document_saas
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=documents
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_FORCE_PATH_STYLE=true

# Production AWS S3: set S3_REGION + S3_BUCKET, leave S3_ENDPOINT empty,
# S3_FORCE_PATH_STYLE=false, and use EC2 IAM role (no access keys).

# mock = deterministic local embeddings/chat (no API key).
# openai = requires OPENAI_API_KEY.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# SePay billing (QR bank transfer)  . Leave the key empty in local dev to skip
# webhook auth; production refuses to boot without it.
SEPAY_WEBHOOK_API_KEY=
SEPAY_BANK_CODE=
SEPAY_BANK_ACCOUNT=
SEPAY_ACCOUNT_NAME=
