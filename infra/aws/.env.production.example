# Copy to /opt/docvault/.env on EC2. Never commit real secrets.

NODE_ENV=production

# Public URLs (must match DNS A records + Let's Encrypt certs)
WEB_URL=https://app.vaultdocs.cloud
API_URL=https://api.vaultdocs.cloud
BETTER_AUTH_URL=https://api.vaultdocs.cloud
NEXT_PUBLIC_API_URL=https://api.vaultdocs.cloud

# openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me

# OTP via Resend (required in production — console is blocked).
OTP_DELIVERY=resend
RESEND_API_KEY=re_xxxxxxxx
# After verifying vaultdocs.cloud in Resend dashboard:
OTP_FROM=DocVault <noreply@vaultdocs.cloud>
# Until domain is verified, Resend only allows sending TO your account email
# when using: OTP_FROM=DocVault <onboarding@resend.dev>

# Supabase — runtime uses RLS role via transaction pooler (:6543).
# Admin/direct URL (:5432) only for migrations (not in containers).
DATABASE_URL=postgresql://docvault_app:STRONG_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_ADMIN_URL=postgresql://postgres:ADMIN_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Redis on the same Compose network (not ElastiCache)
REDIS_URL=redis://redis:6379

# S3 — leave keys empty when EC2 IAM role has s3 permissions
# Leave S3_ENDPOINT unset for real AWS S3 (unlike MinIO local).
S3_REGION=ap-southeast-1
S3_BUCKET=docvault-documents-123456789012
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY=
S3_SECRET_KEY=

# AI (required in production)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# SePay
SEPAY_WEBHOOK_API_KEY=
SEPAY_BANK_CODE=
SEPAY_BANK_ACCOUNT=
SEPAY_ACCOUNT_NAME=
